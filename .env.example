# Скопируйте в .env и заполните значения.
# Разместите .env в корне проекта или в папке telegram_bot.

# Токен бота от @BotFather
TELEGRAM_API_TOKEN=1234567890:ABCdefGHI...

# Ключ OpenAI (для GPT-4o-mini)
OPENAI_API_KEY=sk-...

# URL MCP-сервера (по умолчанию http://127.0.0.1:8765)
MCP_SERVER_URL=http://127.0.0.1:8765
